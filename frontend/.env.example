# Copy to .env.local for local development (never commit .env.local)

# Server-side: used by the public [slug] page to fetch from the backend.
BACKEND_URL=http://localhost:8080
REVALIDATE_SECRET=local-dev-secret

# Browser-side: used by the dashboard (login/register/me). Must be NEXT_PUBLIC_.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Backend environment variables.
# Local dev works with zero config (H2 + defaults). These are for PRODUCTION (Render).

# Activate the production profile (Postgres/Neon)
SPRING_PROFILES_ACTIVE=prod

# Neon Postgres (JDBC form). Get these from the Neon dashboard connection string.
#   DATABASE_URL=jdbc:postgresql://<host>/<db>?sslmode=require
DATABASE_URL=
DB_USERNAME=
DB_PASSWORD=

# Frontend on-demand revalidation target (your Vercel deployment)
REVALIDATE_URL=https://<your-app>.vercel.app/api/revalidate
# Must match REVALIDATE_SECRET on the frontend. Generate a long random value.
REVALIDATE_SECRET=
